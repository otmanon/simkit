# ---------------------------------------------------------------------------
# Python bytecode + compiled extensions
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------------------------------
# Packaging / distribution artifacts
#   produced by:  python -m build, pip install -e ., setup.py sdist, twine
# ---------------------------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
.installed.cfg
MANIFEST
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
env/
ENV/
.env/
.venv/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# Test, coverage, type-check, lint caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.tox/
.nox/
.cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
*.cover
*.py,cover

# ---------------------------------------------------------------------------
# Documentation build output
#   produced by:  sphinx-build, sphinx-autoapi
# ---------------------------------------------------------------------------
docs/_build/
docs/autoapi/
# Tutorial notebooks are checked out here from the simkit-tutorials repo at
# docs-build time only -- never committed to this repo.
docs/tutorials/

# ---------------------------------------------------------------------------
# Notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Polyscope / Dear ImGui session files (dropped wherever a script is run)
# ---------------------------------------------------------------------------
.polyscope.ini
imgui.ini

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS metadata
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------------------------
# Logs / databases
# ---------------------------------------------------------------------------
*.log
*.sqlite
*.db

# ---------------------------------------------------------------------------
# Project-specific media artifacts produced by examples / renders
# ---------------------------------------------------------------------------
*.mp4
*.mov
*.png
*.gif

# ---------------------------------------------------------------------------
# Example runtime artifacts: cached subspaces, simulation results, blender
# scenes, etc. Anything under examples/<demo>/results/ is regeneratable and
# should not be committed.
# ---------------------------------------------------------------------------
examples/cache/
examples/**/cache/
examples/**/results/
examples/**/*.npy
examples/**/*.npz
examples/**/*.blend
examples/**/*.blend1
imgui.ini
.polyscope.ini
imgui.ini
